{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "sqlew suggest",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|EnterPlanMode|enter_plan_mode|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "sqlew track-plan",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash|shell_command|shell|exec_command",
        "hooks": [
          {
            "type": "command",
            "command": "sqlew pr-adr",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "sqlew save",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "sqlew check-completion",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "ExitPlanMode|exit_plan_mode",
        "hooks": [
          {
            "type": "command",
            "command": "sqlew on-exit-plan",
            "timeout": 60
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sqlew on-subagent-stop",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sqlew on-stop",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "sqlew on-exit-plan",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sqlew on-prompt",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sqlew on-session-start",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
